#pragma once
// ─────────────────────────────────────────────────────────────────────────────
//  SECRETS TEMPLATE
//  Copy this file to secrets.h (same folder) and fill in your own values.
//  secrets.h is gitignored and must never be committed. Included by config.h.
// ─────────────────────────────────────────────────────────────────────────────

// ─── WiFi credentials ────────────────────────────────────────────────────────
#define WIFI_SSID            "YOUR_WIFI_SSID"
#define WIFI_PASSWORD        "YOUR_WIFI_PASSWORD"

// ─── Web UI remote-access auth (HTTP Basic Auth for non-LAN connections) ─────
// Required only when the device is reachable from outside your LAN.
#define WEB_AUTH_USER        "admin"
#define WEB_AUTH_PASS        "change-me"

// ─── OTA firmware-flashing password ──────────────────────────────────────────
#define OTA_PASSWORD         "change-me"

// ─── DuckDNS dynamic DNS (optional — leave domain "" to disable) ─────────────
#define DUCKDNS_DOMAIN       ""          // e.g. "mytent"  → mytent.duckdns.org
#define DUCKDNS_TOKEN        ""          // from duckdns.org → your account page
